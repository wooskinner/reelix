rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      // Users can read their own doc.
      allow read: if request.auth != null && request.auth.uid == uid;

      // Users can create their own doc on signup, but never with
      // subscription fields already set.
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && !('plan' in request.resource.data)
                    && !('subscriptionEnd' in request.resource.data)
                    && !('planDuration' in request.resource.data);

      // Users can update their own doc, but can NEVER touch subscription
      // fields — only the Cloudflare Worker (service-account auth) can.
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['plan', 'planDuration', 'subscriptionEnd', 'activatedAt']);

      allow delete: if false;

      // Watch history subcollection: users can manage their own.
      match /watchHistory/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Pending activations are written/read only by the Worker's
    // service-account credentials, which bypass these rules entirely
    // (Admin-style OAuth2 tokens are not subject to security rules).
    // No client — authenticated or not — should ever touch this collection.
    match /pending_activations/{docId} {
      allow read, write: if false;
    }
  }
}
